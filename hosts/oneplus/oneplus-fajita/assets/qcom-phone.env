# Give a short window to interrupt autoboot. U-Boot is built with keyed
# autoboot, so random/stale serial input will not abort boot; type `menu` or
# press Ctrl-C during this window to stop at the U-Boot prompt.
bootdelay=1
bootstopkey=menu
bootretry=1
stdin=serial,button-kbd
stdout=serial,vidconsole
stderr=serial,vidconsole

# Fastboot is keen to use the address from kconfig, but we
# allocate its buffer at runtime.
fastboot=fastboot -l $fastboot_addr_r usb 0

# Load address for EFI payloads. Some Qualcomm U-Boot builds do not define
# kernel_addr_r/loadaddr, and an empty load address makes fatload/bootefi
# print usage. Keep this below the first reserved region shown by bdinfo
# on fajita: RAM starts at 0x80000000 and first reserved block starts at
# 0x85700000, so 0x80200000 leaves plenty of room for the small EFI loader.
loadaddr=0x80200000
kernel_addr_r=0x80200000
efi_addr_r=0x80200000

# Set up a block map pointing to the Android userdata partition, which
# contains the nested NixOS disk image. Keep this self-contained so the
# automatic boot path and the boot-menu path behave the same way.
preboot=
setup_nixos_blkmap=scsi scan; part start scsi 0 userdata userdata_start; part size scsi 0 userdata userdata_size; blkmap destroy root; blkmap create root; blkmap map root 0 0x${userdata_size} linear scsi 0 0x${userdata_start}; blkmap dev 0; blkmap part

# Shortcut to enable USB serial gadget and disable bootretry
serial_gadget=setenv stdin serial,button-kbd,usbacm; setenv stdout serial,vidconsole,usbacm; setenv stderr serial,vidconsole,usbacm; setenv bootretry -1; echo Enabled U-Boot console serial gadget

# bootretry will run this command over and over, if we fail once
# then bail out to the boot menu instead (with a pause to read
# the error message)
#bootcmd=bootefi bootmgr; pause; run menucmd

boot_nixos=run setup_nixos_blkmap; qcom_ab_success mark || echo qcom_ab_success failed; fatload blkmap 0:2 $efi_addr_r /EFI/BOOT/BOOTAA64.EFI; bootefi $efi_addr_r $fdtcontroladdr
bootcmd=run boot_nixos; echo NixOS boot returned or failed; pause; run menucmd

# Open the boot menu and keep it as the active boot command for this U-Boot
# session. This is not persisted across reboots, but prevents returning from a
# menu entry (for example enabling the serial gadget) from continuing the
# already-pending autoboot into NixOS.
menucmd=setenv bootcmd run menucmd; bootmenu -1

# Pause is used so the output can be read on the display
bootmenu_0=Boot NixOS=run boot_nixos; pause
bootmenu_1=Enable serial console gadget=run serial_gadget; exit
bootmenu_2=Enable USB mass storage=echo "Press any key to exit UMS mode"; ums 0 scsi 0
bootmenu_3=Enable fastboot mode=run fastboot
# Disabling bootretry means we'll just drop the shell
bootmenu_4=Drop to shell=setenv bootretry -1
bootmenu_5=Reset device=reset
bootmenu_6=Dump clocks=clk dump; pause
bootmenu_7=Dump environment=printenv; pause
bootmenu_8=Board info=bdinfo; pause
bootmenu_9=Dump bootargs=fdt print /chosen bootargs; pause

# U-Boot button interrupts use exact labels from `button list`.
# On fajita this reports `Volume down`, not `Volume Down`.
# Hold Volume down during U-Boot startup to open the recovery menu.
button_cmd_0_name=Volume down
button_cmd_0=run menucmd
